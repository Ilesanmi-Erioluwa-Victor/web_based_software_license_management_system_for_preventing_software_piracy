APP_NAME=LicenseManager
APP_ENV=production
APP_KEY=generate-a-random-64-char-key-here
APP_URL=https://your-app.onrender.com

DB_CONNECTION=mongodb
DB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net
DB_DATABASE=license_manager

SESSION_LIFETIME=86400

BREVO_API_KEY=your-brevo-api-key-v3
BREVO_FROM=noreply@your-domain.com
BREVO_FROM_NAME=License Manager

RATE_LIMIT_PER_MINUTE=60
